# ── Multiplicadores de precio ──────────────────────────────────────────────
# Precio Público  = Costo × MULT_PUBLICO
MULT_PUBLICO=2.3

# Precio Mayoreo  = Costo × MULT_MAYOREO
MULT_MAYOREO=1.35

